# Default mode is free local rule classification.
OPSPILOT_AI_PROVIDER=rules

# Default storage is local JSON. Set postgres only after running database/schema.sql.
OPSPILOT_REPOSITORY=file
# OPSPILOT_REPOSITORY=postgres
# DATABASE_URL=postgres://user:password@localhost:5432/opspilot
# DATABASE_SSL=false

# Development session controls. Try owner, manager, or staff.
OPSPILOT_DEV_ROLE=owner
OPSPILOT_DEV_USER_NAME=Demo Owner

# Used to sign prototype session cookies. Set a strong value outside local dev.
OPSPILOT_SESSION_SECRET=replace-with-a-long-random-secret

# Mock Gmail connector label used until real Google OAuth is added.
OPSPILOT_GMAIL_ACCOUNT=ops@brightops.example

# Optional real Gmail OAuth. If all three are set, Gmail Connect starts OAuth.
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/connectors/gmail/callback
# OPSPILOT_TOKEN_ENCRYPTION_KEY=replace-with-a-long-random-token-key

# To enable real OpenAI classification, set both:
# OPSPILOT_AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# Optional. Defaults to gpt-4.1-mini if omitted.
OPENAI_MODEL=gpt-4.1-mini
